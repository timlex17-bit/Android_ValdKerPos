<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cartOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dim overlay -->
    <View
        android:id="@+id/viewDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <!-- Right drawer panel (full height, top aligned) -->
    <LinearLayout
        android:id="@+id/cartRoot"
        android:layout_width="360dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="12dp">

        <!-- Header (inside drawer, always visible) -->
        <RelativeLayout
            android:id="@+id/cartHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvCartTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Karosa"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#111827" />

            <ImageButton
                android:id="@+id/btnCloseCart"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#111827"
                android:contentDescription="Close cart" />

            <!-- ✅ NEW: Set All order type (global) -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupSetAllType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvCartTitle"
                android:layout_marginTop="10dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSetAllDineIn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Set All: Dine-In"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#111827"
                    app:chipBackgroundColor="@android:color/white"
                    app:chipStrokeColor="#E5E7EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:checkedIconVisible="false"
                    app:ensureMinTouchTargetSize="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSetAllTakeOut"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Set All: Take-Out"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#111827"
                    app:chipBackgroundColor="@android:color/white"
                    app:chipStrokeColor="#E5E7EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:checkedIconVisible="false"
                    app:ensureMinTouchTargetSize="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSetAllDelivery"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Set All: Delivery"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#111827"
                    app:chipBackgroundColor="@android:color/white"
                    app:chipStrokeColor="#E5E7EB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:checkedIconVisible="false"
                    app:ensureMinTouchTargetSize="false" />
            </com.google.android.material.chip.ChipGroup>

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#11000000" />

        <!-- ✅ CONTENT AREA (mengisi ruang, supaya footer tetap di bawah) -->
        <FrameLayout
            android:id="@+id/cartContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvCartEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your cart is empty"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:padding="16dp"
                android:visibility="gone" />

            <!-- Cart list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false" />
        </FrameLayout>

        <!-- Footer (subtotal + actions) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Subtotal row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Subtotal"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111827" />
            </LinearLayout>

            <!-- Continue payment (kuning/orange) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinuePayment"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Kontinua Pagamentu"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#F97316"
                app:cornerRadius="14dp" />

            <!-- Cancel order (outline orange) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelOrder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Kansela Order"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#F97316"
                android:backgroundTint="@android:color/white"
                app:cornerRadius="14dp"
                app:strokeWidth="2dp"
                app:strokeColor="#F97316" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
