<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSettingsContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#22C55E"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvTopTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/title_settings"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivHeaderAction"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_refresh"
                android:padding="8dp"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="@android:color/white" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/rootSettings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F6F7FB"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <!-- Header -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvTitleSettings"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_shop_settings"
                            android:textColor="#111827"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progressSettings"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:visibility="gone" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- LANGUAGE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_language"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/settings_language_desc"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/spinnerLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_spinner_rounded"
                            android:padding="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SERVER -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardServer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_server"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="#E5E7EB"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBaseUrl"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/settings_base_url_hint"
                                android:inputType="textUri"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveBaseUrl"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="#FFFFFF"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/settings_save_server"
                            android:textAllCaps="false"
                            android:textColor="#111827"
                            app:cornerRadius="14dp"
                            app:strokeColor="#E5E7EB"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- PRINTER -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPrinter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_printer_title"
                                android:textColor="#111827"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/viewPrinterDot"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/bg_status_dot_red" />

                            <TextView
                                android:id="@+id/tvPrinterStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/settings_printer_not_connected"
                                android:textColor="#6B7280"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPrinterSelected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/settings_selected_printer_empty"
                            android:textColor="#111827"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnOpenPrinterSettings"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:backgroundTint="#FFFFFF"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="@string/title_printer_settings"
                                android:textAllCaps="false"
                                android:textColor="#111827"
                                app:cornerRadius="14dp"
                                app:strokeColor="#E5E7EB"
                                app:strokeWidth="1dp" />

                            <Space
                                android:layout_width="12dp"
                                android:layout_height="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTestPrint"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:backgroundTint="#FFFFFF"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="@string/settings_test_print"
                                android:textAllCaps="false"
                                android:textColor="#111827"
                                app:cornerRadius="14dp"
                                app:strokeColor="#E5E7EB"
                                app:strokeWidth="1dp" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchAutoPrint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/settings_auto_print_after_payment"
                            android:textColor="#111827" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/label_paper_width"
                            android:textColor="#111827"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupPaperWidth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:chipSpacingHorizontal="10dp"
                            app:chipSpacingVertical="10dp"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPaper58"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:clickable="true"
                                android:text="@string/paper_width_58mm"
                                android:textColor="#111827"
                                app:checkedIconVisible="false"
                                app:chipBackgroundColor="@color/chip_paper_bg_selector"
                                app:chipCornerRadius="14dp"
                                app:chipStrokeColor="@color/chip_paper_stroke_selector"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPaper80"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:clickable="true"
                                android:text="@string/paper_width_80mm"
                                android:textColor="#111827"
                                app:checkedIconVisible="false"
                                app:chipBackgroundColor="@color/chip_paper_bg_selector"
                                app:chipCornerRadius="14dp"
                                app:chipStrokeColor="@color/chip_paper_stroke_selector"
                                app:chipStrokeWidth="1dp" />

                        </com.google.android.material.chip.ChipGroup>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- BRANDING -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardImages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_branding"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/settings_shop_logo"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_marginTop="10dp"
                            app:cardBackgroundColor="#F3F4F6"
                            app:cardCornerRadius="44dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#E5E7EB"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/imgLogoPreview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/settings_logo_preview"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_store" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPickLogo"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="#FFFFFF"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/settings_choose_logo"
                            android:textAllCaps="false"
                            android:textColor="#111827"
                            app:cornerRadius="14dp"
                            app:strokeColor="#E5E7EB"
                            app:strokeWidth="1dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SHOP PROFILE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_shop_profile"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="#E5E7EB"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etShopName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/settings_name_required_hint"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="#E5E7EB"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etShopAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/settings_address_required_hint"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="#E5E7EB"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etShopPhone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/settings_phone_required_hint"
                                android:inputType="phone"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="#E5E7EB"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etShopEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/settings_email_hint"
                                android:inputType="textEmailAddress"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveShop"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="18dp"
                            android:backgroundTint="#16A34A"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/settings_save_changes"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            app:cornerRadius="18dp"
                            app:elevation="0dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>