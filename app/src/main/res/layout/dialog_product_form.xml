<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F9FAFB"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitleProductForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Product"
        android:textColor="#111827"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#F3F4F6"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Details"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111827" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Name *"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilProdSku"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="SKU (optional)"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/barcode_generate"
                        app:endIconContentDescription="Scan SKU"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdSku"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilProdCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Code *"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_barcode"
                        app:endIconContentDescription="Scan Code"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:id="@+id/blockItemType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Item Type"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#6B7280" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#FFFFFF"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#D1D5DB">

                            <Spinner
                                android:id="@+id/spProdItemType"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:background="@android:color/transparent"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp" />
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Category"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#D1D5DB">

                        <Spinner
                            android:id="@+id/spProdCategory"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:background="@android:color/transparent"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Description"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="#F3F4F6"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock and Pricing"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111827" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Stock *"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdStock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Buy price * (e.g. 1.50)"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdBuy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Sell price * (e.g. 2.50)"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdSell"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Weight * (e.g. 0.35)"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProdWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="#F3F4F6"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unit and Supplier"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Unit"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#D1D5DB">

                        <Spinner
                            android:id="@+id/spProdUnit"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:background="@android:color/transparent"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Supplier"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#D1D5DB">

                        <Spinner
                            android:id="@+id/spProdSupplier"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:background="@android:color/transparent"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="#F3F4F6"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Image"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111827" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectImage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="14dp"
                        android:text="Select Product Image"
                        android:textAllCaps="false"
                        android:textColor="#22C55E"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        app:strokeColor="#22C55E"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#D1D5DB">

                        <ImageView
                            android:id="@+id/imgPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />
                    </com.google.android.material.card.MaterialCardView>

                    <ProgressBar
                        android:id="@+id/progressProdForm"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Product Settings"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111827"/>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/swTrackStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Track stock"
                        android:textColor="#111827"
                        android:checked="true"/>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/swProdActive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Product Active"
                        android:textColor="#111827"
                        android:checked="true"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="22dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>