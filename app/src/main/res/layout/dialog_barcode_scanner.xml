<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scannerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000">

    <!-- Card Container -->
    <LinearLayout
        android:id="@+id/scannerCard"
        android:layout_width="340dp"
        android:layout_height="420dp"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="12dp">

        <!-- Small Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvScannerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan Barcode"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827" />

            <ImageButton
                android:id="@+id/btnCloseScanner"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aponta kámara ba kódigu barra. Skaner sei halo eskaneamentu."
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp" />

        <!-- Area Camera -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">

            <com.journeyapps.barcodescanner.DecoratedBarcodeView
                android:id="@+id/barcodeView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Overlay Frame -->
            <View
                android:id="@+id/scanFrame"
                android:layout_width="230dp"
                android:layout_height="230dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_scan_frame" />

            <!-- Small Text Under Frame -->
            <TextView
                android:id="@+id/tvScanBoxText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="12dp"
                android:text="Scan here"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#FFFFFF" />

        </FrameLayout>

        <!-- Last Preview Result Scan -->
        <TextView
            android:id="@+id/tvLast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last: -"
            android:textSize="12sp"
            android:textColor="#111827"
            android:layout_marginTop="10dp" />

    </LinearLayout>

</FrameLayout>