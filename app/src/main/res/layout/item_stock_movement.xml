<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stock_movement_item_name_placeholder"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stock_movement_meta_placeholder"
            android:textSize="12sp"
            android:alpha="0.75"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stock_movement_date_placeholder"
            android:textSize="12sp"
            android:alpha="0.75"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stock_movement_type_placeholder"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvQty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stock_movement_qty_short_placeholder"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stock_movement_stock_placeholder"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRef"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stock_movement_ref_placeholder"
            android:layout_marginTop="6dp"
            android:alpha="0.9"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>