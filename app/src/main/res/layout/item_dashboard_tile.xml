<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="132dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="22dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp"
    android:backgroundTint="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- ICON CONTAINER (soft background) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:backgroundTint="#F2F4FF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_icon_container"
                android:padding="11dp">

                <ImageView
                    android:id="@+id/imgTileIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:contentDescription="Menu icon"/>

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Arrow indicator -->
        <ImageView
            android:id="@+id/imgArrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_forward_24"
            app:tint="#9CA3AF"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvTileTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Point of Sale"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#1F2937"
            android:layout_marginTop="12dp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/iconContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- SUBTITLE -->
        <TextView
            android:id="@+id/tvTileSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Start selling products"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvTileTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>