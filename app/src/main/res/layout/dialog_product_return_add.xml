<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F9FAFB"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitleProductReturnAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Product Return"
        android:textColor="#111827"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Main Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#F3F4F6"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Return Details"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111827" />

                    <!-- Return Mode -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Return Type"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgReturnMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbByInvoice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#22C55E"
                            android:checked="true"
                            android:text="By Invoice"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/rbManual"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#22C55E"
                            android:text="Manual"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RadioGroup>

                    <!-- Invoice Section -->
                    <LinearLayout
                        android:id="@+id/layoutInvoiceSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Invoice"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#FFFFFF"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#D1D5DB">

                            <Spinner
                                android:id="@+id/spOrder"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:background="@android:color/transparent"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvCustomerAuto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Customer: -"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Item in Invoice"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#FFFFFF"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#D1D5DB">

                            <Spinner
                                android:id="@+id/spOrderItem"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:background="@android:color/transparent"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="Qty Return"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxStrokeColor="#D1D5DB"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etQty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Qty"
                                android:inputType="number"
                                android:textColor="#111827"
                                android:textColorHint="#9CA3AF" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Unit Price"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxStrokeColor="#D1D5DB"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUnitPrice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="false"
                                android:enabled="false"
                                android:focusable="false"
                                android:importantForAutofill="no"
                                android:inputType="none"
                                android:longClickable="false"
                                android:textColor="#111827"
                                android:textIsSelectable="false" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddItem"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#22C55E"
                            android:text="Add Invoice Item"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                    <!-- Manual Section -->
                    <LinearLayout
                        android:id="@+id/layoutManualSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvManualHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Manual return does not require invoice or customer."
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Product"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#FFFFFF"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#D1D5DB">

                            <Spinner
                                android:id="@+id/spManualProduct"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:background="@android:color/transparent"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="Qty Return"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxStrokeColor="#D1D5DB"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etManualQty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Qty"
                                android:inputType="number"
                                android:textColor="#111827"
                                android:textColorHint="#9CA3AF" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Unit Price"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxStrokeColor="#D1D5DB"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:hintTextColor="#6B7280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etManualUnitPrice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textColor="#111827"
                                android:textColorHint="#9CA3AF" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddManualItem"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#22C55E"
                            android:text="Add Manual Item"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                    <!-- Shared Note -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Reason / note"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#D1D5DB"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:hintTextColor="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="#F3F4F6"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Items Preview"
                        android:textColor="#111827"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPreviewEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="No items yet"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPreview"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="10dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvItemsPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="22dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>