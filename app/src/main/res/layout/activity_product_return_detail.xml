<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F7FB"
    android:padding="16dp">

    <!-- Header Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:padding="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Return #1"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#111827" />

        <TextView
            android:id="@+id/tvInvoice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Invoice: -"
            android:textSize="14sp"
            android:textColor="#374151"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tvCustomer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer: -"
            android:textSize="14sp"
            android:textColor="#374151"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvReturnedBy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Returned by: -"
            android:textSize="14sp"
            android:textColor="#374151"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvReturnedAt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Returned: -"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Note: -"
            android:textSize="14sp"
            android:textColor="#374151"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Table Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.6"
            android:text="Product"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:gravity="end"
            android:text="Qty"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:gravity="end"
            android:text="Price"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:gravity="end"
            android:text="Total"
            android:textStyle="bold"
            android:textColor="#111827" />
    </LinearLayout>

    <!-- Items Recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:padding="12dp" />

    <!-- Footer totals + print button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:padding="12dp"
        android:orientation="vertical"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Qty: 0 • Total: $0.00"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#111827" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Print Return"
            android:layout_marginTop="10dp" />
    </LinearLayout>

</LinearLayout>